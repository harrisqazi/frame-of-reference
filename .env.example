# Local testing only — set the same in Vercel for production. Never commit real passwords to GitHub.

# Gmail (recommended) — use an App Password, not your normal Gmail password
SMTP_USER=your.email@gmail.com
SMTP_PASS=your_16_char_app_password
NOTIFY_EMAIL=admin@pooly.org

# Optional Resend fallback
# RESEND_API_KEY=
# RESEND_FROM=

# Optional Google Sheets backup
# GOOGLE_CLIENT_EMAIL=
# GOOGLE_PRIVATE_KEY=
# SPREADSHEET_ID=
